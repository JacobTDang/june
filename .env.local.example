# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase — from Project Settings > API (public, safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase service role — server-only, bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API key — server-only (Google Cloud > APIs & Services > Credentials)
YOUTUBE_API_KEY=

# Google OAuth client — same client as the Supabase Google provider. Server-only.
# Needed to refresh the YouTube token so the connection persists.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Owner email for the /metrics dashboard (owner-only).
ADMIN_EMAIL=

# Max people who can hold a seat in the app. Optional; defaults to 20.
SIGNUP_CAP=20
